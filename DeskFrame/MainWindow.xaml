<Window x:Class="DeskFrame.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:tray="http://schemas.lepo.co/wpfui/2022/xaml/tray"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:local="clr-namespace:DeskFrame" xmlns:ui1="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:properties="clr-namespace:DeskFrame.Properties;assembly=DeskFrame"
        xmlns:prop="clr-namespace:DeskFrame.Properties"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800" Initialized="Window_Initialized" Loaded="Window_Loaded">
    <tray:NotifyIcon Grid.Row="0" FocusOnLeftClick="True"  
                  
                   Name="TrayIcon" MenuOnRightClick="True"
                   TooltipText="DeskBoard" >
        <tray:NotifyIcon.Menu>
            <ContextMenu MinWidth="65">
                <!-- versionHeader is kept (referenced from code-behind) but hidden in the build. -->
                <MenuItem Name="versionHeader" Header="version" Visibility="Collapsed" FontSize="10" IsEnabled="False" HorizontalAlignment="Center" Background="{x:Null}" FontFamily="Segoe Print"/>

                <ui:ToggleSwitch x:Name="AutorunToggle" Content="{x:Static prop:Lang.TrayContextMenu_StartOnLogin}"
                             Checked="AutorunToggle_CheckChanged"  Unchecked="AutorunToggle_CheckChanged"  />

                <Separator Margin="0,3,0,3"/>

                <ui:MenuItem x:Name="Settings_Button" Header="{x:Static prop:Lang.TrayContextMenu_Settings}"
                             Icon="{ui:SymbolIcon Symbol=Settings20}" Click="Settings_Button_Click" />

                <MenuItem Name="addBoard" Height="34" Header="Добавить доску" Click="addBoard_Click" Icon="{ui:SymbolIcon Symbol=Board20}"/>
                <MenuItem x:Name="Exit_Button" Height="34"
                          Header="{x:Static prop:Lang.TrayContextMenu_Exit}" Click="ExitApp" Icon="{ui:SymbolIcon Symbol=ArrowExit20}" />

            </ContextMenu>
        </tray:NotifyIcon.Menu>
    </tray:NotifyIcon>

</Window>
