<ui:FluentWindow x:Class="DeskFrame.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml" 
        xmlns:local="clr-namespace:DeskFrame"
        xmlns:properties="clr-namespace:DeskFrame.Properties;assembly=DeskFrame"
        xmlns:prop="clr-namespace:DeskFrame.Properties"
        ExtendsContentIntoTitleBar="True"
        mc:Ignorable="d"    
        Background="#66232323" 
        WindowStyle="None" 
        ResizeMode="NoResize"
        Height="630" 
        Width="460"
        Closing="FluentWindow_Closing">
    <Grid>
        <StackPanel>
            <ui:TitleBar Title="{x:Static prop:Lang.DeskFrameFrameSettings_TitleBarText}" Name="Titlebar" Padding="8,0,0,0" Height="30"  CanMaximize="False" ShowMinimize="False" ApplicationTheme="Dark" ShowMaximize="False" >
                <ui:TitleBar.Icon>
                    <ui:ImageIcon Source="/ico.png" Margin="0,0,6,0" />
                </ui:TitleBar.Icon>
                <ui:TitleBar.TrailingContent>
                    <StackPanel Orientation="Horizontal">
                        <ui:Button x:Name="AboutButton"  Icon="{ui:SymbolIcon Symbol=Info24}" HorizontalAlignment="Right" VerticalAlignment="Top" Grid.Column="2" Margin="0,0,5,0" Height="30" Padding="10,0,10,0" Click="AboutButton_Click"/>
                    </StackPanel>
                </ui:TitleBar.TrailingContent>
            </ui:TitleBar>
            <StackPanel Orientation="Vertical" Margin="10,25,0,0" >
            </StackPanel>

            <StackPanel >
                <ui:Button x:Name="ExportSettingsButton" Content="{x:Static prop:Lang.DeskFrameFrameSettings_ExportSettings}" Click="ExportSettingsButton_Click" Margin="10,10,0,0"/>
                <StackPanel Orientation="Horizontal">
                    <ui:Button x:Name="DefaultFrameStyleButton" Content="{x:Static prop:Lang.DeskFrameFrameSettings_DefaultFrameStyle}"  Margin="10,20,0,0" Click="DefaultFrameStyleButton_Click"/>
                    <ui:Button x:Name="ResetDefaultFrameStyleButton" Content="{x:Static prop:Lang.DeskFrameFrameSettings_ResetDefaultStyle}" Icon="{ui:SymbolIcon ArrowReset24}" Margin="10,20,0,0" Click="ResetDefaultFrameStyleButton_Click" />
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <ui:Button x:Name="ReloadAllFramesButton" Content="{x:Static prop:Lang.DeskFrameFrameSettings_ReloadAllFramesButton}" Click="ReloadAllFramesButton_Click" Margin="10,20,0,0"/>
                    <ui:Button x:Name="ManageFrameButton" Content="{x:Static prop:Lang.DeskFrameFrameSettings_ManageFrameButton}" Click="ManageFrameButton_Click" Margin="10,20,0,0"/>
                </StackPanel>

                <ui:ToggleSwitch x:Name="AutoUpdateToggleSwitch" Content="{x:Static prop:Lang.DeskFrameFrameSettings_AutoUpdate}" Margin="10,20,0,0" Click="AutoUpdateToggleSwitch_Click"/>
                <ui:ToggleSwitch x:Name="DoubleClickToHideSwitch" Content="{x:Static prop:Lang.DeskFrameFrameSettings_DoubleClickHide}" Margin="10,20,0,0" Click="DoubleClickToHideSwitch_Click"/>

                <Separator HorizontalAlignment="Center" Margin="20,10,20,10" Width="461"/>


                <StackPanel>
                    <Grid Margin="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="125"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal" Grid.Column="0" HorizontalAlignment="Right">
                            <Border HorizontalAlignment="Left" Height="25" Background="#FF333333" Padding="8,2" CornerRadius="4"  Margin="0,0,8,0">
                                <TextBlock Text="ALT"  Foreground="LightGray" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <Border HorizontalAlignment="Left" Height="25" Background="#FF333333" Padding="8,2" CornerRadius="4">
                                <TextBlock Text="{x:Static prop:Lang.DeskFrameFrameSettings_Drag}"  Foreground="LightGray" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Grid.Column="1" Text="{x:Static prop:Lang.DeskFrameFrameSettings_SnapDescription}" TextWrapping="Wrap" Foreground="LightGray" VerticalAlignment="Center" Margin="16,0,0,0"/>
                            <TextBlock Grid.Column="1" Text="{x:Static prop:Lang.DeskFrameFrameSettings_ReorderDescription}" TextWrapping="Wrap" Foreground="LightGray" VerticalAlignment="Center" Margin="16,0,0,0"/>
                        </StackPanel>

                    </Grid>

                    <Grid Margin="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="125"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal" Grid.Column="0" HorizontalAlignment="Right">
                            <Border HorizontalAlignment="Left" Height="25" Background="#FF333333" Padding="8,2" CornerRadius="4"  Margin="0,0,8,0">
                                <TextBlock Text="CTRL" Foreground="LightGray"  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <Border HorizontalAlignment="Left" Height="25" Background="#FF333333" Padding="8,2" CornerRadius="4">
                                <TextBlock Text="{x:Static prop:Lang.DeskFrameFrameSettings_Scroll}" Foreground="LightGray"  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </StackPanel>
                        <TextBlock Grid.Column="1" Text="{x:Static prop:Lang.DeskFrameFrameSettings_ChangeIconSizeDescription}" TextWrapping="Wrap" Foreground="LightGray"  VerticalAlignment="Center" Margin="16,0,0,0"/>
                    </Grid>

                    <Grid Margin="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="125"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal" Grid.Column="0" HorizontalAlignment="Right">
                            <Border HorizontalAlignment="Left" Height="25" Background="#FF333333" Padding="8,2" CornerRadius="4">
                                <TextBlock Text="F2" Foreground="LightGray"  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </StackPanel>
                        <TextBlock Grid.Column="1" Text="{x:Static prop:Lang.DeskFrameFrameSettings_RenameFilesDescription}" TextWrapping="Wrap" Foreground="LightGray"  VerticalAlignment="Center" Margin="16,0,0,0"/>
                    </Grid>

                    <Grid Margin="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="125"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border HorizontalAlignment="Right" Height="25" Background="#FF333333" Padding="8,2" CornerRadius="4" >
                            <TextBlock Text="{x:Static prop:Lang.DeskFrameFrameSettings_Scroll}"  Foreground="LightGray" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="1">
                            <TextBlock Grid.Column="1" Text="{x:Static prop:Lang.DeskFrameFrameSettings_ScrollUpDescription}" TextWrapping="Wrap" Foreground="LightGray" VerticalAlignment="Center" Margin="16,0,0,0"/>
                            <TextBlock Grid.Column="1" Text="{x:Static prop:Lang.DeskFrameFrameSettings_ScrollDownDescription}" TextWrapping="Wrap" Foreground="LightGray" VerticalAlignment="Center" Margin="16,0,0,0"/>
                        </StackPanel>

                    </Grid>

                </StackPanel>
            </StackPanel>
        </StackPanel>

        <StackPanel HorizontalAlignment="Left" VerticalAlignment="Bottom" Orientation="Horizontal">
            <!-- "Support me on Ko-fi" badge removed from the build. -->
            <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom">
                <Border CornerRadius="5"
                        Height="62"
                        VerticalAlignment="Bottom"
                        Margin="10,10,0,8"
                        Background="#0CFFFFFF"  
                        BorderThickness="1"
                        x:Name="DragWinBorder" 
                        Cursor="Hand"
                        ToolTipService.InitialShowDelay="100" 
                        MouseLeftButtonDown="DragWinBorder_MouseLeftButtonDown">
                    <Border.ToolTip>
                        <ToolTip MaxWidth="400" Placement="Right" HorizontalOffset="5" >
                            <StackPanel>
                                <TextBlock Text="DragWin" FontSize="14" FontWeight="Bold" Foreground="#FFABB8FF"  Margin="0,0,0,8"/>

                                <TextBlock Text="{x:Static prop:Lang.DeskFrameFrameSettings_DragWinToolTip_MainFeatures}" Foreground="White" FontSize="12"  Margin="0,0,0,2"/>
                                <TextBlock Text="{x:Static prop:Lang.DeskFrameFrameSettings_DragWinToolTip_Feature1}" Foreground="White" FontSize="12"/>
                                <TextBlock Text="{x:Static prop:Lang.DeskFrameFrameSettings_DragWinToolTip_Feature2}" Foreground="White" FontSize="12"/>
                                <TextBlock Text="{x:Static prop:Lang.DeskFrameFrameSettings_DragWinToolTip_Feature3}" Foreground="White" FontSize="12"/>
                                <TextBlock Text="{x:Static prop:Lang.DeskFrameFrameSettings_DragWinToolTip_Feature4}" Foreground="White" FontSize="12"/>
                                <TextBlock Text="{x:Static prop:Lang.DeskFrameFrameSettings_DragWinToolTip_Feature5}" Foreground="White" FontSize="12"/>

                                <TextBlock Text="{x:Static prop:Lang.DeskFrameFrameSettings_DragWinToolTip_DoubleClickToGithub}" Foreground="#FFD2DAFF" FontSize="12"  Margin="0,10,0,0"/>
                            </StackPanel>
                        </ToolTip>
                    </Border.ToolTip>
                    <Grid>
                        <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                            <Image Margin="0,4,0,5" Source="/Icon/DragWin.ico"
                                   SnapsToDevicePixels="True" 
                                   UseLayoutRounding="True"
                                   RenderOptions.BitmapScalingMode="Fant" 
                                   Width="32"/>
                            <Grid Margin="5,0,5,5">
                                <Grid>
                                    <TextBlock FontSize="12" Text="DragWin" Foreground="Black" Padding="1.8,0,1.8,0" Margin="0,-2.5,0,0" TextAlignment="Center" HorizontalAlignment="Center" >
                                        <TextBlock.Effect>
                                            <BlurEffect Radius="2" KernelType="Box"/>
                                        </TextBlock.Effect>
                                    </TextBlock>
                                    <TextBlock FontSize="12" Text="DragWin" Foreground="Black" Padding="1.8,0,1.8,0" Margin="0,-2.5,0,0" TextAlignment="Center" HorizontalAlignment="Center">
                                        <TextBlock.Effect>
                                            <BlurEffect Radius="2" KernelType="Box"/>
                                        </TextBlock.Effect>
                                    </TextBlock>
                                    <TextBlock FontSize="12" Text="DragWin" Foreground="#F1F1F1" Padding="1.8,0,1.8,0" Margin="0,-3,0,0" TextAlignment="Center" HorizontalAlignment="Center" MaxHeight="90"/>
                                </Grid>
                            </Grid>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border CornerRadius="5" Margin="10,10,0,8"
                        Background="#0CFFFFFF"  
                        BorderThickness="1"
                        x:Name="EQSBorder" 
                        Cursor="Hand"
                        ToolTipService.InitialShowDelay="100" 
                        MouseLeftButtonDown="EQSBorder_MouseLeftButtonDown">
                    <Border.ToolTip>
                        <ToolTip MaxWidth="400" Placement="Right" HorizontalOffset="5" >
                            <StackPanel>
                                <TextBlock Text="Everything Quick Search" FontSize="14" FontWeight="Bold" Foreground="#FFABB8FF"  Margin="0,0,0,8"/>
                                <TextBlock Text="{x:Static prop:Lang.DeskFrameFrameSettings_DragWinToolTip_MainFeatures}" Foreground="White" FontSize="12"  Margin="0,0,0,2"/>
                                <TextBlock Text="{x:Static prop:Lang.DeskFrameFrameSettings_EQSToolTip_Feature1}" Foreground="White" FontSize="12"/>
                                <TextBlock Text="{x:Static prop:Lang.DeskFrameFrameSettings_EQSToolTip_Feature2}" Foreground="White" FontSize="12"/>
                                <TextBlock Text="{x:Static prop:Lang.DeskFrameFrameSettings_EQSToolTip_Feature3}" Foreground="White" FontSize="12"/>
                                <TextBlock Text="{x:Static prop:Lang.DeskFrameFrameSettings_DragWinToolTip_DoubleClickToGithub}" Foreground="#FFD2DAFF" FontSize="12"  Margin="0,10,0,0"/>
                            </StackPanel>
                        </ToolTip>
                    </Border.ToolTip>
                    <Grid Width="90" >
                        <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                            <Image Margin="0,5,0,5" Source="/Icon/EverythingQuickSearch.ico"
                                   SnapsToDevicePixels="True" 
                                   UseLayoutRounding="True"
                                   RenderOptions.BitmapScalingMode="Fant" 
                                   Width="32"/>
                            <Grid Margin="5,0,5,5">
                                <Grid>
                                    <TextBlock FontSize="12" Text="Everything QS" TextWrapping="Wrap" Foreground="Black" Padding="1.8,0,1.8,0" Margin="0,-2.5,0,0" TextAlignment="Center" HorizontalAlignment="Center" >
                                        <TextBlock.Effect>
                                            <BlurEffect Radius="2" KernelType="Box"/>
                                        </TextBlock.Effect>
                                    </TextBlock>
                                    <TextBlock FontSize="12" Text="Everything QS" TextWrapping="Wrap" Foreground="Black" Padding="1.8,0,1.8,0" Margin="0,-2.5,0,0" TextAlignment="Center" HorizontalAlignment="Center">
                                        <TextBlock.Effect>
                                            <BlurEffect Radius="2" KernelType="Box"/>
                                        </TextBlock.Effect>
                                    </TextBlock>
                                    <TextBlock FontSize="12" Text="Everything QS" TextWrapping="Wrap" Foreground="#F1F1F1" Padding="1.8,0,1.8,0" Margin="0,-3,0,0" TextAlignment="Center" HorizontalAlignment="Center" MaxHeight="90"/>
                                </Grid>
                            </Grid>
                        </StackPanel>
                    </Grid>
                </Border>
                
            </StackPanel>
        </StackPanel>


        <StackPanel Orientation="Horizontal"  HorizontalAlignment="Right" Margin="0,0,10,5" VerticalAlignment="Bottom">
            <Label Content="{x:Static prop:Lang.DeskFrameFrameSettings_MadewithSpace}" HorizontalAlignment="Left" VerticalAlignment="Center" Foreground="DimGray"/>
            <ui:SymbolIcon Symbol="Heart20" Filled="True" Margin="0,-2,0,0" Foreground="DimGray"/>
        </StackPanel>
       
    </Grid>
</ui:FluentWindow>
